{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "files": {
    "includes": [
      "**",
      "!node_modules",
      "!packages/.fhir-cache",
      "!packages/types-fhir/index.d.ts",
      "!packages/types-fhir/r*.d.ts",
      "!packages/types-fhir/test",
      "!packages/fhir-zod/src",
      "!bun.lock"
    ]
  }
}
