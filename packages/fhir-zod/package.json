{
  "name": "@reasonhealth/fhir-zod",
  "version": "1.0.7",
  "description": "Zod schemas for FHIR R4, R4B, R5",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reason-healthcare/fhir-types-workspace.git",
    "directory": "packages/fhir-zod"
  },
  "homepage": "https://github.com/reason-healthcare/fhir-types-workspace/tree/main/packages/fhir-zod#readme",
  "bugs": {
    "url": "https://github.com/reason-healthcare/fhir-types-workspace/issues"
  },
  "exports": {
    "./r4": {
      "types": "./src/r4.ts",
      "import": "./dist/r4.js",
      "default": "./dist/r4.js"
    },
    "./r4b": {
      "types": "./src/r4b.ts",
      "import": "./dist/r4b.js",
      "default": "./dist/r4b.js"
    },
    "./r5": {
      "types": "./src/r5.ts",
      "import": "./dist/r5.js",
      "default": "./dist/r5.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "generate": "fhir-generate --config ./generate.config.ts",
    "build": "bun build src/r4.ts src/r4b.ts src/r5.ts --target node --format esm --external zod --outdir dist --sourcemap",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@reasonhealth/fhir-ts-codegen": "workspace:*",
    "@types/bun": "latest"
  }
}
